DISCORD_TOKEN=your_discord_bot_token_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Local development ──────────────────────────────────────────────────────
# Path to your credentials JSON file (used when running locally)
GOOGLE_CREDENTIALS_PATH=your-league-name-credentials.json

# ── Railway / hosted deployment ────────────────────────────────────────────
# On Railway, paste the ENTIRE contents of your credentials JSON file here.
# Leave blank when running locally (GOOGLE_CREDENTIALS_PATH is used instead).
GOOGLE_CREDENTIALS_JSON=

# UID prefix used by /newmatch for leagues without GodForge (2-4 uppercase letters)
LEAGUE_PREFIX=FRH

# Google Drive folder ID for the top-level shared stats folder
# Create the folder in Drive, share it with your staff, then paste the ID from the URL:
# https://drive.google.com/drive/folders/THIS_PART_IS_THE_ID
PARENT_DRIVE_FOLDER_ID=your_drive_folder_id_here

# Channel IDs (right-click channel in Discord > Copy ID)
SCREENSHOT_CHANNEL_ID=
JSON_CHANNEL_ID=
ADMIN_REPORT_CHANNEL_ID=

# Staff role IDs (right-click role in Discord > Copy ID)
# Comma-separated list of role IDs that can use staff commands
STAFF_ROLE_IDS=

# Optional explicit stat admin user IDs, comma-separated.
STAT_ADMIN_USER_IDS=

# OCR confidence threshold. Below this requires review.
CONFIDENCE_THRESHOLD=90

# Starting community points balance for new guild-scoped wallets.
STARTING_BALANCE=500

# Optional persistent economy store path. On Railway, mount a volume at /app/data
# and set this to /app/data/forgelens_economy.json.
FORGELENS_ECONOMY_PATH=

# Optional future gate for ForgeLens community-points commands. Verify policy before production.
BETTING_ENABLED=false
